{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "ElDoc",
  "version": "0.1.0",
  "identifier": "com.eldoc.desktop",
  "build": {
    "frontendDist": "../../../packages/web/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm --filter @mc/web dev",
    "beforeBuildCommand": "pnpm --filter @mc/web build"
  },
  "app": {
    "windows": [
      {
        "title": "ElDoc",
        "width": 1400,
        "height": 900,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "externalBin": ["bin/eldoc-mcp"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
