{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions plus sidecar execution for the bundled MCP CLI",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "fs:default",
    "shell:allow-execute",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "bin/eldoc-mcp",
          "sidecar": true,
          "args": true
        }
      ]
    },
    {
      "identifier": "fs:allow-applocaldata-read",
      "allow": [{ "path": "$APPLOCALDATA/**" }]
    },
    {
      "identifier": "fs:allow-applocaldata-write",
      "allow": [{ "path": "$APPLOCALDATA/**" }]
    }
  ]
}
